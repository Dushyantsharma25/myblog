<%- include("../up/header.ejs") %>
<section class="section">
<h1>Hello <%= Username %> </h1>

<form action="/profile?user=<%= Username %>" method="post" id="submit_blog">
    <label for="title">@ Title</label>
    <input type="text" name="title" placeholder="Enter Title of your Post" id="title" minlength="5" required>

    <label for="textjab">@ Content</label>
    <textarea name="text" id="textjab"
        placeholder="Get started by creating your first Blog"
        maxlength="11000" minlength="20" required></textarea>

    <button type="submit">Post</button>
</form>


<h1>Posts</h1>

<div class="posts-container">
  <% posts.forEach((post, index) => { %>
    <% if (Username === post.user) { %>

      <div class="post-card">
        
        <div class="post-header">
          <span class="post-author">
            post created by <%= post.user %> on
          </span>
          <span class="post-date">
            <%= post.date_created %> | at <%= post.time_created %>
          </span>
        </div>

        <h2 class="post-title"><%= post.title %></h2>

        <p class="post-content">
          <%= post.text %>
        </p>

        <div class="imp_buttons" style="display: flex;gap: 10px;">
          <form action="/delete?user=<%= Username %>" method="POST" >
              <input type="hidden" name="index" value="<%= index %>">
              <button type="submit" class="delete-btn">
                  Delete Post
              </button>
          </form>
          <form action="/update?user=<%= Username %>" method="POST">
              <input type="hidden" name="index" value="<%= index %>">
              <button type="submit" class="update-btn">
                  Update Post
              </button>
          </form>
        </div>

      </div>

    <% } %>
  <% }) %>
</div>

</section>

<%- include("../up/footer.ejs") %>

