<%- include("../up/header.ejs") %>

<section class="section">
    <h1>Update Post</h1>

    <form action="/post_update" method="post" id="submit_blog">

        <input type="hidden" name="index" value="<%= index %>">

        <label for="title">@ Title</label>
        <input type="text" name="title" id="title" minlength="5" required value="<%= post.title %>">

        <label for="textjab">@ Content</label>
        <textarea name="text" d="textjab" maxlength="11000" minlength="20" required><%= post.text %></textarea>

        <button type="submit">Update</button>
    </form>

</section>

<%- include("../up/footer.ejs") %>