<%- include("../up/header.ejs") %>

<section class="section">
    <h1>Update Post</h1>
    <form action="/post_update?user=<%= Username %>" method="post" id="submit_blog">
        <label for="title">@ Title</label>
        <input type="number" name="index" hidden value="<%= index %>">
        <input type="text" name="title" placeholder="Enter Title of your Post" id="title" minlength="5" required value="<%= posts[index].title %>">

        <label for="textjab">@ Content</label>
        <textarea name="text" id="textjab"
            placeholder="Get started by creating your first Blog"
            maxlength="11000" minlength="20" required><%= posts[index].text %></textarea>

        <button type="submit">Update</button>
    </form>

</section>



<%- include("../up/footer.ejs") %>